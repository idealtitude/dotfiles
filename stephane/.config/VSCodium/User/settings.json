            "tab.hoverBackground": "#313131",
            "tab.activeModifiedBorder": "#399ee6",
            "editorPane.background": "#0d0d0d",
            "editor.background": "#171717",
            "editor.foreground": "#ffffff",
            "editorLineNumber.foreground": "#4a4a4a",
            "editorLineNumber.activeForeground": "#979797",
            "editorCursor.background": "#000000",
            "editorCursor.foreground": "#b366ff",
            "editor.selectionBackground": "#b366ff30",
            "editor.lineHighlightBackground": "#242424",
            "editorLink.activeForeground": "#b366ff",
            "editorWhitespace.foreground": "#4a4a4a",
            "editorIndentGuide.background": "#313131",
            "editorIndentGuide.activeBackground": "#b366ff",
            "editorRuler.foreground": "#313131",
            "editorBracketMatch.border": "#8f52cc",
            "editorBracketMatch.background": "#b366ff20",
            "editor.foldBackground": "#ffef9e30",
            "editorOverviewRuler.border": "#313131",
