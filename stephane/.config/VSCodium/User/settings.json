            "activityBar.activeBackground": "#b366ff13",
            "activityBar.activeFocusBorder": "#b366ff",
            "sideBar.background": "#111111",
            "sideBarSectionHeader.background": "#1e1e1e",
            "minimap.selectionHighlight": "#b366ff80",
