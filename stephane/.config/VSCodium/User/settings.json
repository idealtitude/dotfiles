    },
    "editor.tokenColorCustomizations": {
        "[generated-dark]": {
            "textMateRules": [
                {
                    "scope": "invalid",
                    "settings": {
                        "foreground": "#f07171"
                    }
                },
                {
                    "scope": [
                        "meta.embedded",
                        "source.groovy.embedded",
                        "meta.template.expression"
                    ],
                    "settings": {
                        "foreground": "#ffffff"
                    }
                },
                {
                    "scope": [
                        "variable",
                        "support.variable.property.dom",
                        "support.variable.dom",
                        "support.variable.property",
                        "punctuation.separator.parameter",
                        "string.interpolated.pug variable"
                    ],
                    "settings": {
                        "foreground": "#ffffff"
                    }
                },
                {
                    "scope": [
                        "comment",
                        "punctuation.definition.comment"
                    ],
                    "settings": {
                        "foreground": "#707070"
                    }
                },
                {
                    "scope": [
                        "string",
                        "punctuation.definition.string"
                    ],
                    "settings": {
                        "foreground": "#a4ba91"
                    }
                },
                {
                    "scope": "constant.character.escape",
                    "settings": {
                        "foreground": "#b366ff"
                    }
                },
                {
                    "scope": [
                        "keyword",
                        "constant.language.import-export-all"
                    ],
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": [
                        "entity.name.type",
                        "support.type.primitive",
                        "support.type.builtin",
                        "meta.type.annotation entity.name.type",
                        "meta.type.parameters entity.name.type"
                    ],
                    "settings": {
                        "foreground": "#8a9fc1"
                    }
                },
                {
                    "scope": [
                        "keyword.control",
                        "storage",
                        "support.type",
                        "keyword.operator.expression",
                        "keyword.operator.new"
                    ],
                    "settings": {
                        "foreground": "#b366ff"
                    }
                },
                {
                    "scope": [
                        "entity.name.function",
                        "support.class",
                        "support.function",
                        "new.expr entity.name.type",
                        "entity.other.inherited-class"
                    ],
                    "settings": {
                        "foreground": "#ffef9e"
                    }
                },
                {
                    "scope": [
                        "punctuation.definition.typeparameters",
                        "keyword.operator.type",
                        "keyword.operator.optional",
                        "source.tsx punctuation.section.embedded",
                        "source.jsx punctuation.section.embedded"
                    ],
                    "settings": {
                        "foreground": "#ff9214"
                    }
                },
                {
                    "scope": "constant",
                    "settings": {
                        "foreground": "#8a9fc1"
                    }
                },
                {
                    "scope": [
                        "constant.numeric",
                        "constant.language"
                    ],
                    "settings": {
                        "foreground": "#dbb99e"
                    }
                },
                {
                    "scope": [
                        "variable.parameter",
                        "parameter.variable",
                        "meta.function.parameter variable",
                        "source.rust meta.type_params.rust"
                    ],
                    "settings": {
                        "foreground": "#dbb99e"
                    }
                },
                {
                    "scope": [
                        "punctuation",
                        "meta.brace"
                    ],
                    "settings": {
                        "foreground": "#a6a6a6"
                    }
                },
                {
                    "scope": "comment.block.documentation entity.name.type",
                    "settings": {
                        "foreground": "#ff9214"
                    }
                },
                {
                    "scope": [
                        "variable.language.this",
                        "variable.language.special.self"
                    ],
                    "settings": {
                        "foreground": "#b366ff"
                    }
                },
                {
                    "scope": [
                        "meta.tag.metadata.doctype entity.name.tag",
                        "meta.tag.metadata.doctype punctuation.definition.tag",
                        "meta.tag.metadata.doctype string",
                        "meta.tag.metadata.doctype entity.other.attribute-name.html",
                        "meta.tag.sgml.doctype"
                    ],
                    "settings": {
                        "foreground": "#a6a6a6"
                    }
                },
                {
                    "scope": "entity.name.tag",
                    "settings": {
                        "foreground": "#b366ff"
                    }
                },
                {
                    "scope": "meta.tag string",
                    "settings": {
                        "foreground": "#a4ba91"
                    }
                },
                {
                    "scope": "meta.attribute punctuation.definition.string",
                    "settings": {
                        "foreground": "#a6a6a6"
                    }
                },
                {
                    "scope": [
                        "meta.tag entity.other.attribute-name",
                        "entity.other.attribute-name.html"
                    ],
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": [
                        "constant.character.entity",
                        "punctuation.definition.entity"
                    ],
                    "settings": {
                        "foreground": "#dbb99e"
                    }
                },
                {
                    "scope": [
                        "entity.name.section.markdown",
                        "markup.heading.setext"
                    ],
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": "punctuation.definition.list",
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": "meta.separator.markdown",
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": "markup.inline.raw",
                    "settings": {
                        "foreground": "#b366ff"
                    }
                },
                {
                    "scope": "markup.bold",
                    "settings": {
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "markup.italic",
                    "settings": {
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": [
                        "meta.link punctuation.definition.string",
                        "meta.image punctuation.definition.string"
                    ],
                    "settings": {
                        "foreground": "#a6a6a6"
                    }
                },
                {
                    "scope": [
                        "link",
                        "markup.underline.link",
                        "constant.other.reference.link.markdown"
                    ],
                    "settings": {
                        "foreground": "#ffef9e"
                    }
                },
                {
                    "scope": "markup.quote",
                    "settings": {
                        "foreground": "#dbb99e"
                    }
                },
                {
                    "scope": [
                        "entity.name.tag.css",
                        "entity.name.tag.wildcard"
                    ],
                    "settings": {
                        "foreground": "#a4ba91"
                    }
                },
                {
                    "scope": [
                        "entity.other.attribute-name.class",
                        "entity.other.attribute-name punctuation.definition.entity"
                    ],
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": [
                        "entity.other.attribute-name.pseudo-element",
                        "entity.other.attribute-name.pseudo-class",
                        "constant.other.color"
                    ],
                    "settings": {
                        "foreground": "#b366ff"
                    }
                },
                {
                    "scope": [
                        "entity.other.attribute-name.id",
                        "entity.other.attribute-name.id punctuation.definition.entity"
                    ],
                    "settings": {
                        "foreground": "#ffef9e"
                    }
                },
                {
                    "scope": "source.css constant.numeric",
                    "settings": {
                        "foreground": "#a4ba91"
                    }
                },
                {
                    "scope": [
                        "meta.property-name",
                        "support.type.property-name"
                    ],
                    "settings": {
                        "foreground": "#dbb99e"
                    }
                },
                {
                    "scope": [
                        "meta.property-value",
                        "meta.property-value constant.other",
                        "support.constant.property-value"
                    ],
                    "settings": {
                        "foreground": "#ffef9e"
                    }
                },
                {
                    "scope": "variable.parameter.url",
                    "settings": {
                        "foreground": "#dbb99e"
                    }
                },
                {
                    "scope": "punctuation.definition.variable",
                    "settings": {
                        "foreground": "#ffffff"
                    }
                },
                {
                    "scope": [
                        "punctuation.section.embedded.begin.php",
                        "punctuation.section.embedded.end.php"
                    ],
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": "entity.name.section",
                    "settings": {
                        "foreground": "#ffef9e"
                    }
                },
                {
                    "scope": "support.type.property-name.json",
                    "settings": {
                        "foreground": "#ffc157"
                    }
                },
                {
                    "scope": "markup.inserted",
                    "settings": {
                        "foreground": "#78bd65"
                    }
                },
                {
                    "scope": "markup.changed",
                    "settings": {
                        "foreground": "#399ee6"
                    }
                },
                {
                    "scope": "markup.deleted",
                    "settings": {
                        "foreground": "#f07171"
                    }
                },
                {
                    "scope": "meta.diff.header",
                    "settings": {
                        "foreground": "#399ee6",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "meta.diff.range",
                    "settings": {
                        "foreground": "#b366ff"
                    }
                }
            ]
        }
    },
    "debug.console.fontSize": 13,
    "terminal.integrated.fontSize": 13,
    "python.linting.pylintPath": "/usr/bin/pylint",
    "python.linting.mypyEnabled": true,
    "python.linting.mypyArgs": [
        "--ignore-missing-imports",
        "--follow-imports=silent",
        "--show-column-numbers",
        "--strict"
    ],
    "python.diagnostics.sourceMapsEnabled": true,
    "python.insidersChannel": "weekly",
    "python.languageServer": "Jedi",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairsHorizontal": false,
    "editor.guides.highlightActiveBracketPair": false,
    "python.formatting.blackPath": "/usr/bin/black",
    "python.formatting.provider": "black",
    "editor.hover.above": false,
    "markdown.preview.fontSize": 13,
    "notebook.markup.fontSize": 13,
    "C_Cpp.intelliSenseEngine": "Tag Parser",
}
