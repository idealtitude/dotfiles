    "New class hdr": {
        "prefix": "cls1",
        "body": [
            "class ${1:cn}",
            "{",
            "  public:",
            "\t${1:cn}();",
            "\t~${1:cn}();",
            "  private:",
            "\t$0",
            "};",
            "\n"
        ],
        "description": "Add a new class header"
    },
    "New class cpp": {
        "prefix": "cls2",
        "body": [
            "${1:cn}::${1:cn}() : $0\n{\n}\n",
            "${1:cn}::~${1:cn}()\n{\n}\n"
        ],
        "description": "Add"
    },
    "Header guard": {
        "prefix": "hdr",
        "body": [
            "// file.h",
            "#ifndef ${1:hn}_H",
            "#define ${1:hn}_H",
            "\n$0\n",
            "#endif\n"
        ],
        "description": "Add header guard"
    },
    "New struct": {
        "prefix": "stc",
        "body": [
            "struct $0\n{\n\t\n};\n"
        ],
        "description": "Add a new struct"
    },
