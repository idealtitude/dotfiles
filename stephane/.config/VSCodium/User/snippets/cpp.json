        "description": "Add if else if statement"
    },
    "If else if else stmt": {
        "prefix": "ifeie",
        "body": [
            "if ($0)\n{\n\t\n}\nelse if ()\n{\n\t\n}\nelse\n{\n\t\n}\n"
