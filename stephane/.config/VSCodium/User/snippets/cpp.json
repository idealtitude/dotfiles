    "For loop": {
        "prefix": "for",
        "body": [
            "for (int i = 0; i < $0; ++i)\n{\n\t\n}\n"
        ],
        "description": "Add a for loop"
    },
    "For in": {
        "prefix": "fore",
        "body": [
            "for (auto &e : $0)\n{\n\t\n}\n"
