    },
    "Empty for1": {
        "prefix": "for1",
        "body": [
            "for (${1:fe}; ${1:fe}; ++${1:fe})\n{\n\t$0\n}\n"
        ],
        "description": "Add an empty for loop (ver. 1)"
    },
    "Empty for2": {
        "prefix": "for2",
        "body": [
            "for ( ; ; )\n{\n\t$0\n}\n"
        ],
        "description": "Add an empty for loop (ver. 2)"
    },
    "Vec iter loop": {
        "prefix": "vecitl",
        "body": [
            "for (std::vector<${1:vt}>::iterator ${2:itn} = ${3:vn}.begin() ; ${2:itn} != ${3:vn}.end(); ++${2:itn})\n{\n",
            "\t*${2:itn} $0;",
            "}\n"
        ],
        "description": "Add vector iterator for loop"
    },
    "Map iter": {
        "prefix": "mapit",
        "body": [
            "std::map<c${1:mt}, >::iterator $0"
        ],
        "description": "Add"
    },
    "Map iter loop": {
        "prefix": "mapitl",
        "body": [
            "for (std::map<${1:mto}, ${2:mtt}>::iterator ${3:itn} = ${4:vn}.begin(); ${3:itn} != ${4:vn}.end(); ++${3:itn})\n{\n",
            "\t${3:itn}->first << ${3:itn}->second $0;\n",
            "}\n"
        ],
        "description": "Add vector iterator for loop"
    },
