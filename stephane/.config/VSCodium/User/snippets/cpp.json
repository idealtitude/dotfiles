{
    "Preproc in": {
        "prefix": "in",
        "body": [
            "#include <$0>"
        ],
        "description": "Add empty #include"
    },
    "Preproc in2": {
        "prefix": "in2",
        "body": [
            "#include \"$0\""
        ],
        "description": "Add empty local #include \"\""
